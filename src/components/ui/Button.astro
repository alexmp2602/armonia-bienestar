---
type Variant = "primary" | "secondary";

interface Props {
  href?: string;
  variant?: Variant;
  target?: "_blank" | "_self" | "_parent" | "_top";
  rel?: string;
}

const {
  href = "#contacto",
  variant = "primary",
  target,
  rel,
} = Astro.props as Props;

const classes: Record<Variant, string> = {
  primary:
    "bg-[var(--color-text)] text-white hover:bg-[var(--color-accent-dark)]",

  secondary:
    "bg-transparent text-[var(--color-text)] border border-black/15 hover:border-black/40",
};

const safeRel = target === "_blank" ? (rel ?? "noopener noreferrer") : rel;
---

<a
  href={href}
  target={target}
  rel={safeRel}
  class:list={[
    "inline-flex items-center justify-center rounded-full px-6 py-3 text-sm font-medium transition-all duration-300 ease-out",
    "focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--color-accent)]",
    classes[variant],
  ]}
>
  <slot />
</a>
