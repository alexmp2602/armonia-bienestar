---
import Button from "../ui/Button.astro";
import Reveal from "../motion/Reveal.astro";
import heroImage from "../../assets/images/hero-wellness.webp";
---

<section class="relative min-h-screen overflow-hidden pt-28">
  <div
    class="container grid min-h-[calc(100vh-7rem)] items-center gap-12 py-16 lg:grid-cols-[1.05fr_0.95fr]"
  >
    <div class="max-w-2xl">
      <Reveal>
        <p
          class="mb-5 text-sm font-medium uppercase tracking-[0.28em] text-black/50"
        >
          Terapia de masajes · Bienestar integral
        </p>
      </Reveal>

      <Reveal delay={0.08}>
        <h1
          class="heading text-balance text-6xl font-semibold leading-[0.92] md:text-7xl lg:text-8xl"
        >
          Un espacio pensado para desconectar.
        </h1>
      </Reveal>

      <Reveal delay={0.16}>
        <p
          class="mt-7 max-w-xl text-lg leading-8 text-[var(--color-muted)] md:text-xl"
        >
          Masajes y tratamientos orientados a relajar el cuerpo, recuperar
          energía y volver a sentir equilibrio en un entorno cálido, profesional
          y cuidado.
        </p>
      </Reveal>

      <Reveal delay={0.24}>
        <div class="mt-9 flex flex-col gap-4 sm:flex-row">
          <Button href="#contacto">Reservar por WhatsApp</Button>
          <Button href="#servicios" variant="secondary">Ver servicios</Button>
        </div>
      </Reveal>
    </div>

    <div class="relative">
      <div
        class="absolute -left-8 -top-8 h-40 w-40 rounded-full bg-[var(--color-accent)]/25 blur-3xl"
      >
      </div>

      <Reveal delay={0.18} y={32}>
        <div
          class="relative overflow-hidden rounded-4xl bg-[var(--color-bg-soft)]"
        >
          <img
            src={heroImage.src}
            alt="Espacio de bienestar y masajes premium"
            class="aspect-[4/5] h-full w-full object-cover"
          />

          <div class="absolute inset-0 flex items-end p-8">
            <div class="rounded-3xl bg-white/55 p-5 backdrop-blur-md">
              <p class="text-sm uppercase tracking-[0.22em] text-black/45">
                calma · recuperación · equilibrio
              </p>

              <p class="mt-3 max-w-xs text-lg leading-7 text-black/75">
                Una experiencia sobria y relajante, diseñada para bajar el
                ritmo.
              </p>
            </div>
          </div>
        </div>
      </Reveal>

      <Reveal delay={0.34} y={16}>
        <div
          class="absolute -bottom-6 right-8 rounded-full bg-[var(--color-accent)] px-5 py-3 text-sm font-semibold text-black shadow-xl shadow-black/10"
        >
          Bienestar premium
        </div>
      </Reveal>
    </div>
  </div>
</section>
