---
import Button from "../ui/Button.astro";
import Reveal from "../motion/Reveal.astro";
import heroImage from "../../assets/images/hero-wellness.webp";
---

<section class="relative min-h-screen overflow-hidden pt-28">
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(126,217,87,0.08),transparent_32rem)]"
  >
  </div>

  <div
    class="container relative grid min-h-[calc(100vh-7rem)] items-center gap-14 py-16 lg:grid-cols-[1.05fr_0.95fr]"
  >
    <div class="max-w-2xl">
      <Reveal>
        <p
          class="mb-5 text-sm font-medium uppercase tracking-[0.28em] text-black/45"
        >
          Bienestar masculino · recuperación corporal
        </p>
      </Reveal>

      <Reveal delay={0.08}>
        <h1
          class="heading text-balance text-6xl font-semibold leading-[0.9] md:text-7xl lg:text-[5.5rem]"
        >
          Recuperá tu bienestar.
        </h1>
      </Reveal>

      <Reveal delay={0.16}>
        <p
          class="mt-7 max-w-xl text-lg leading-8 text-[var(--color-muted)] md:text-xl"
        >
          Masajes, recuperación física y cuidado personal masculino en un
          espacio moderno, sobrio y diseñado para bajar el ritmo.
        </p>
      </Reveal>

      <Reveal delay={0.24}>
        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
          <Button href="#contacto"> Reservar una sesión </Button>

          <Button href="#servicios" variant="secondary">
            Ver tratamientos
          </Button>
        </div>
      </Reveal>

      <Reveal delay={0.32}>
        <div
          class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-black/45"
        >
          <span class="flex items-center gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent-dark)]"
            ></span>

            Atención personalizada
          </span>

          <span class="flex items-center gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent-dark)]"
            ></span>

            Ambiente reservado
          </span>

          <span class="flex items-center gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent-dark)]"
            ></span>

            Bienestar & estética
          </span>
        </div>
      </Reveal>
    </div>

    <div class="relative">
      <div
        class="absolute -left-10 -top-10 h-44 w-44 rounded-full bg-[var(--color-accent)]/20 blur-3xl"
      >
      </div>

      <Reveal delay={0.18} y={32}>
        <div
          class="relative overflow-hidden rounded-[2.5rem] bg-[var(--color-bg-soft)] shadow-2xl shadow-black/[0.06]"
        >
          <img
            src={heroImage.src}
            alt="Espacio premium de bienestar y recuperación masculina"
            class="aspect-[4/5] h-full w-full object-cover"
          />

          <div
            class="absolute inset-0 bg-gradient-to-t from-black/35 via-transparent to-transparent"
          >
          </div>

          <div class="absolute inset-0 flex items-end p-8">
            <div
              class="max-w-sm rounded-[1.75rem] border border-white/10 bg-white/50 p-5 backdrop-blur-md"
            >
              <p class="text-sm uppercase tracking-[0.22em] text-black/45">
                recuperación · descanso · cuidado personal
              </p>

              <p class="mt-3 text-lg leading-7 text-black/75">
                Una experiencia moderna y sobria pensada para hombres que buscan
                bajar la tensión y sentirse mejor.
              </p>
            </div>
          </div>
        </div>
      </Reveal>

      <Reveal delay={0.34} y={16}>
        <div
          class="absolute -bottom-6 right-8 rounded-full border border-black/5 bg-[var(--color-accent)] px-5 py-3 text-sm font-semibold text-black shadow-xl shadow-black/10"
        >
          Bienestar premium masculino
        </div>
      </Reveal>
    </div>
  </div>
</section>
