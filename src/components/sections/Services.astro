---
import { services } from "../../data/services";
import Reveal from "../motion/Reveal.astro";
---

<section id="servicios" class="relative overflow-hidden py-24 md:py-32">
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(126,217,87,0.06),transparent_28rem)]"
  >
  </div>

  <div class="container relative">
    <div class="max-w-3xl">
      <Reveal>
        <p
          class="mb-4 text-sm font-medium uppercase tracking-[0.28em] text-black/45"
        >
          Servicios
        </p>
      </Reveal>

      <Reveal delay={0.08}>
        <h2
          class="heading text-balance text-5xl font-semibold leading-[0.95] md:text-7xl"
        >
          Bienestar, recuperación y cuidado personal.
        </h2>
      </Reveal>

      <Reveal delay={0.16}>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-[var(--color-muted)]">
          Tratamientos orientados a descargar tensión física, recuperar energía
          y acompañar una rutina moderna de bienestar y cuidado masculino.
        </p>
      </Reveal>
    </div>

    <div class="mt-20 grid gap-16">
      <!-- Wellness -->
      <div>
        <Reveal>
          <div class="mb-8 flex items-center gap-4">
            <span class="h-px w-12 bg-[var(--color-accent-dark)]"></span>

            <p
              class="text-sm font-medium uppercase tracking-[0.24em] text-black/45"
            >
              Bienestar & recuperación
            </p>
          </div>
        </Reveal>

        <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
          {
            services.wellness.map((service, index) => (
              <Reveal delay={0.08 + index * 0.05}>
                <article class="group flex h-full flex-col rounded-[1.9rem] border border-black/8 bg-white/45 p-7 transition duration-500 hover:-translate-y-1 hover:border-black/12 hover:bg-white/70">
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-black/30">0{index + 1}</span>

                    <span class="rounded-full border border-black/8 bg-black/[0.03] px-3 py-1 text-[11px] font-medium uppercase tracking-[0.18em] text-black/45">
                      Unisex
                    </span>
                  </div>

                  <h3 class="heading mt-8 text-3xl font-semibold leading-none">
                    {service.title}
                  </h3>

                  <p class="mt-5 flex-1 text-base leading-7 text-[var(--color-muted)]">
                    {service.description}
                  </p>

                  <div class="mt-8 h-px w-full bg-black/8">
                    <div class="h-px w-0 bg-[var(--color-accent-dark)] transition-all duration-500 group-hover:w-full"></div>
                  </div>
                </article>
              </Reveal>
            ))
          }
        </div>
      </div>

      <!-- Grooming -->
      <div>
        <Reveal>
          <div class="mb-8 flex items-center gap-4">
            <span class="h-px w-12 bg-[var(--color-accent-dark)]"></span>

            <p
              class="text-sm font-medium uppercase tracking-[0.24em] text-black/45"
            >
              Cuidado masculino
            </p>
          </div>
        </Reveal>

        <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
          {
            services.grooming.map((service, index) => (
              <Reveal delay={0.08 + index * 0.06}>
                <article class="group flex h-full flex-col rounded-[1.9rem] border border-black/8 bg-[var(--color-dark)] p-7 text-white transition duration-500 hover:-translate-y-1 hover:bg-[var(--color-dark-soft)]">
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-white/25">0{index + 1}</span>

                    <span class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-[11px] font-medium uppercase tracking-[0.18em] text-white/45">
                      Hombres
                    </span>
                  </div>

                  <h3 class="heading mt-8 text-3xl font-semibold leading-none">
                    {service.title}
                  </h3>

                  <p class="mt-5 flex-1 text-base leading-7 text-white/60">
                    {service.description}
                  </p>

                  <div class="mt-8 h-px w-full bg-white/10">
                    <div class="h-px w-0 bg-[var(--color-accent)] transition-all duration-500 group-hover:w-full"></div>
                  </div>
                </article>
              </Reveal>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
