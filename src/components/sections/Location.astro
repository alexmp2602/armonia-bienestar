---
import Reveal from "../motion/Reveal.astro";
import Button from "../ui/Button.astro";

const mapsUrl =
  "https://www.google.com/maps/search/?api=1&query=Avenida+Pedro+Molina+789+Mendoza";

const whatsappUrl =
  "https://wa.me/5492616215017?text=Hola%2C%20quiero%20consultar%20por%20un%20turno%20en%20Armon%C3%ADa%20%26%20Bienestar";

const instagramUrl = "https://www.instagram.com/armonia.bienestar.masajes/";
---

<section class="relative overflow-hidden bg-[var(--color-bg)] py-24 md:py-32">
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,rgba(126,217,87,0.06),transparent_30rem)]"
  >
  </div>

  <div class="container relative">
    <div
      class="grid gap-10 overflow-hidden rounded-[2.75rem] border border-black/8 bg-white/45 p-6 shadow-2xl shadow-black/[0.04] md:p-10 lg:grid-cols-[1fr_0.92fr] lg:items-center"
    >
      <div>
        <Reveal>
          <p
            class="mb-4 text-sm font-medium uppercase tracking-[0.28em] text-black/45"
          >
            Ubicación & contacto
          </p>
        </Reveal>

        <Reveal delay={0.08}>
          <h2
            class="heading text-balance text-5xl font-semibold leading-[0.95] md:text-7xl"
          >
            Un espacio reservado para bajar el ritmo.
          </h2>
        </Reveal>

        <Reveal delay={0.16}>
          <p class="mt-6 max-w-xl text-lg leading-8 text-[var(--color-muted)]">
            Armonía & Bienestar ofrece una experiencia moderna, discreta y
            profesional en un entorno pensado para relajación, recuperación y
            cuidado personal masculino.
          </p>
        </Reveal>

        <Reveal delay={0.24}>
          <div class="mt-10 flex flex-col gap-4 sm:flex-row">
            <Button href={mapsUrl} target="_blank"> Ver ubicación </Button>

            <Button href={whatsappUrl} variant="secondary" target="_blank">
              Consultar disponibilidad
            </Button>
          </div>
        </Reveal>

        <Reveal delay={0.28}>
          <p class="mt-6 text-sm leading-6 text-[var(--color-muted)]">
            También podés encontrarnos en{" "}
            <a
              href={instagramUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="font-medium text-[var(--color-text)] transition duration-300 hover:text-[var(--color-accent-dark)]"
            >
              Instagram
            </a>
          </p>
        </Reveal>

        <Reveal delay={0.34}>
          <div
            class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-black/40"
          >
            <span class="flex items-center gap-2">
              <span
                class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent-dark)]"
              ></span>

              Atención personalizada
            </span>

            <span class="flex items-center gap-2">
              <span
                class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent-dark)]"
              ></span>

              Ambiente reservado
            </span>

            <span class="flex items-center gap-2">
              <span
                class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent-dark)]"
              ></span>

              Bienestar premium
            </span>
          </div>
        </Reveal>
      </div>

      <Reveal delay={0.18} y={28}>
        <div
          class="rounded-[2rem] border border-black/8 bg-[var(--color-bg-soft)] p-7 lg:p-8"
        >
          <div class="space-y-4">
            <div>
              <p
                class="text-sm font-medium uppercase tracking-[0.22em] text-black/40"
              >
                Dirección
              </p>

              <p class="mt-3 text-2xl font-medium leading-tight">
                Avenida Pedro Molina 789
              </p>

              <p class="mt-2 text-[var(--color-muted)]">Ciudad, Mendoza</p>
            </div>

            <div class="h-px w-full bg-black/10"></div>

            <div>
              <p
                class="text-sm font-medium uppercase tracking-[0.22em] text-black/40"
              >
                Contacto
              </p>

              <a
                href="https://wa.me/5492616215017"
                target="_blank"
                rel="noopener noreferrer"
                class="mt-3 block text-2xl font-medium transition duration-300 hover:text-[var(--color-accent-dark)]"
              >
                +54 9 261 621 5017
              </a>
            </div>

            <div class="h-px w-full bg-black/10"></div>

            <div>
              <p
                class="text-sm font-medium uppercase tracking-[0.22em] text-black/40"
              >
                Horarios
              </p>

              <p class="mt-3 leading-7 text-[var(--color-muted)]">
                Lunes a sábados de 9:00 a 21:00 hs.
                <br />
                Domingos de 10:00 a 18:00 hs.
              </p>
            </div>

            <div class="h-px w-full bg-black/10"></div>

            <div>
              <p
                class="text-sm font-medium uppercase tracking-[0.22em] text-black/40"
              >
                Modalidad
              </p>

              <p class="mt-3 leading-7 text-[var(--color-muted)]">
                Atención con reserva previa y horarios sujetos a disponibilidad.
              </p>
            </div>
          </div>
        </div>
      </Reveal>
    </div>
  </div>
</section>
