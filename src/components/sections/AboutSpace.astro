---
import Reveal from "../motion/Reveal.astro";
import spaceImage from "../../assets/images/space-wellness.webp";
---

<section
  id="espacio"
  class="relative overflow-hidden bg-[var(--color-bg-soft)] py-24 md:py-32"
>
  <div class="container">
    <div
      class="grid gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:gap-20"
    >
      <Reveal y={32}>
        <div
          class="relative overflow-hidden rounded-[2.5rem] bg-[#ddd6cd] shadow-2xl shadow-black/[0.06]"
        >
          <img
            src={spaceImage.src}
            alt="Interior sobrio y premium de Armonía & Bienestar"
            class="aspect-[4/5] h-full w-full object-cover"
          />

          <div
            class="absolute inset-0 bg-gradient-to-t from-black/35 via-transparent to-transparent"
          >
          </div>

          <div
            class="absolute bottom-6 left-6 right-6 rounded-[1.75rem] border border-white/10 bg-white/55 p-5 backdrop-blur-md"
          >
            <p class="text-sm uppercase tracking-[0.22em] text-black/45">
              espacio reservado
            </p>

            <p class="mt-3 max-w-sm text-lg leading-7 text-black/75">
              Un entorno sobrio, limpio y profesional para bajar la tensión y
              recibir atención personalizada.
            </p>
          </div>
        </div>
      </Reveal>

      <div>
        <Reveal delay={0.08}>
          <p
            class="mb-4 text-sm font-medium uppercase tracking-[0.28em] text-black/45"
          >
            Sobre el espacio
          </p>
        </Reveal>

        <Reveal delay={0.16}>
          <h2
            class="heading text-balance text-5xl font-semibold leading-[0.95] md:text-7xl"
          >
            Un entorno sobrio para recuperar cuerpo y mente.
          </h2>
        </Reveal>

        <Reveal delay={0.24}>
          <div
            class="mt-8 space-y-6 text-lg leading-8 text-[var(--color-muted)]"
          >
            <p>
              Armonía & Bienestar propone una experiencia moderna, reservada y
              sin artificios. Un lugar pensado para hombres que buscan
              relajación, recuperación física y cuidado personal en un entorno
              profesional.
            </p>

            <p>
              La estética acompaña la experiencia: tonos cálidos, superficies
              limpias, ritmo pausado y una atención enfocada en que cada sesión
              se sienta cómoda, discreta y efectiva.
            </p>
          </div>
        </Reveal>

        <div class="mt-10 grid gap-4 sm:grid-cols-2">
          <Reveal delay={0.32}>
            <div
              class="h-full rounded-3xl border border-black/10 bg-white/35 p-6 transition duration-500 hover:bg-white/55"
            >
              <p class="text-sm uppercase tracking-[0.22em] text-black/40">
                ambiente
              </p>

              <p class="mt-3 text-xl font-medium">Sobrio y reservado</p>
            </div>
          </Reveal>

          <Reveal delay={0.4}>
            <div
              class="h-full rounded-3xl border border-black/10 bg-white/35 p-6 transition duration-500 hover:bg-white/55"
            >
              <p class="text-sm uppercase tracking-[0.22em] text-black/40">
                enfoque
              </p>

              <p class="mt-3 text-xl font-medium">
                Profesional y personalizado
              </p>
            </div>
          </Reveal>
        </div>
      </div>
    </div>
  </div>
</section>
