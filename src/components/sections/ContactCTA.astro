---
import Button from "../ui/Button.astro";
import Reveal from "../motion/Reveal.astro";

const whatsappUrl =
  "https://wa.me/5492616215017?text=Hola%2C%20quiero%20consultar%20por%20un%20turno%20en%20Armon%C3%ADa%20%26%20Bienestar";
---

<section id="contacto" class="relative overflow-hidden bg-[var(--color-bg)]">
  <div class="py-24 md:py-28">
    <div class="container">
      <div
        class="relative overflow-hidden rounded-[2.75rem] bg-[var(--color-dark)] px-6 py-16 text-white shadow-2xl shadow-black/[0.08] md:px-12 md:py-20 lg:px-20"
      >
        <div
          class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-[var(--color-accent)]/15 blur-3xl"
        >
        </div>

        <div
          class="absolute -bottom-24 left-10 h-72 w-72 rounded-full bg-white/[0.05] blur-3xl"
        >
        </div>

        <div
          class="relative grid gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-end"
        >
          <div>
            <Reveal>
              <p
                class="mb-4 text-sm font-medium uppercase tracking-[0.28em] text-white/45"
              >
                Reservá tu sesión
              </p>
            </Reveal>

            <Reveal delay={0.08}>
              <h2
                class="heading text-balance text-5xl font-semibold leading-[0.95] md:text-7xl"
              >
                Recuperá cuerpo y mente.
              </h2>
            </Reveal>

            <Reveal delay={0.16}>
              <p class="mt-6 max-w-xl text-lg leading-8 text-white/65">
                Coordiná una sesión personalizada según tu necesidad:
                relajación, descarga muscular, recuperación física o cuidado
                personal masculino.
              </p>
            </Reveal>

            <Reveal delay={0.24}>
              <div
                class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-white/40"
              >
                <span class="flex items-center gap-2">
                  <span
                    class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent)]"
                  ></span>

                  Atención personalizada
                </span>

                <span class="flex items-center gap-2">
                  <span
                    class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent)]"
                  ></span>

                  Ambiente reservado
                </span>

                <span class="flex items-center gap-2">
                  <span
                    class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent)]"
                  ></span>

                  Bienestar premium
                </span>
              </div>
            </Reveal>
          </div>

          <Reveal delay={0.28} y={28}>
            <div
              class="rounded-[2rem] border border-white/10 bg-white/[0.04] p-6 transition duration-500 hover:bg-white/[0.06] md:p-8"
            >
              <p class="text-sm uppercase tracking-[0.22em] text-white/40">
                contacto directo
              </p>

              <p class="mt-4 text-2xl font-medium leading-tight">
                Coordiná tu sesión en pocos mensajes.
              </p>

              <p class="mt-4 leading-7 text-white/55">
                Respondemos consultas sobre tratamientos, disponibilidad y tipo
                de atención.
              </p>

              <div class="mt-8">
                <Button href={whatsappUrl} target="_blank">
                  Coordinar por WhatsApp
                </Button>
              </div>

              <div
                class="mt-8 rounded-2xl border border-white/8 bg-black/10 px-4 py-4"
              >
                <p class="text-sm text-white/35">
                  Horarios sujetos a disponibilidad.
                </p>
              </div>
            </div>
          </Reveal>
        </div>
      </div>
    </div>
  </div>
</section>
