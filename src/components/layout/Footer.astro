---
import Reveal from "../motion/Reveal.astro";
import logo from "../../assets/images/logo-horizontal-dark.png";
import {
  Instagram,
  MapPin,
  Phone,
} from "lucide-astro";
---

<footer
  class="relative overflow-hidden bg-[var(--color-dark)] py-14 text-white"
>
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(126,217,87,0.08),transparent_35%)]"
  >
  </div>

  <div class="container relative">
    <div class="grid gap-12 md:grid-cols-[1.1fr_0.9fr] md:items-end">
      <Reveal>
        <div>
          <img
            src={logo.src}
            alt="Armonía & Bienestar"
            class="h-14 w-auto select-none"
            draggable="false"
          />

          <p class="mt-6 max-w-md leading-7 text-white/55">
            Bienestar masculino, recuperación corporal y cuidado personal en un
            entorno moderno, sobrio y profesional.
          </p>
        </div>
      </Reveal>

      <Reveal delay={0.12}>
        <div
          class="grid gap-10 sm:grid-cols-2 md:justify-self-end md:text-right"
        >
          <div>
            <p
              class="mb-4 text-sm font-medium uppercase tracking-[0.22em] text-white/35"
            >
              Navegación
            </p>

            <nav class="flex flex-col gap-3 text-sm text-white/45">
              <a
                href="#servicios"
                class="transition duration-300 hover:text-white"
              >
                Servicios
              </a>

              <a
                href="#experiencia"
                class="transition duration-300 hover:text-white"
              >
                Experiencia
              </a>

              <a
                href="#espacio"
                class="transition duration-300 hover:text-white"
              >
                Espacio
              </a>

              <a
                href="#contacto"
                class="transition duration-300 hover:text-white"
              >
                Contacto
              </a>
            </nav>
          </div>

          <div>
            <p
              class="mb-4 text-sm font-medium uppercase tracking-[0.22em] text-white/35"
            >
              Contacto
            </p>

            <div class="flex flex-col gap-3 text-sm text-white/45">
              <a
                href="https://wa.me/5492616215017"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 transition duration-300 hover:text-white md:justify-end"
              >
                <Phone size={16} strokeWidth={1.75} />
                <span>+54 9 261 621 5017</span>
              </a>

              <a
                href="https://www.google.com/maps/search/?api=1&query=Avenida+Pedro+Molina+789+Mendoza"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 transition duration-300 hover:text-white md:justify-end"
              >
                <MapPin size={16} strokeWidth={1.75} />
                <span>Avenida Pedro Molina 789</span>
              </a>

              <span class="text-white/45">
                Ciudad, Mendoza
              </span>

              <a
                href="https://www.instagram.com/armonia.bienestar.masajes/"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 transition duration-300 hover:text-white md:justify-end"
              >
                <Instagram size={16} strokeWidth={1.75} />
                <span>Instagram</span>
              </a>
            </div>
          </div>
        </div>
      </Reveal>
    </div>

    <div class="mt-14 h-px w-full bg-white/10"></div>

    <Reveal delay={0.18}>
      <div
        class="mt-8 flex flex-col gap-4 text-sm text-white/35 md:flex-row md:items-center md:justify-between"
      >
        <p>
          © {new Date().getFullYear()} Armonía & Bienestar. Todos los derechos
          reservados.
        </p>

        <p>
          Diseñado para una experiencia de bienestar premium.
        </p>
      </div>
    </Reveal>
  </div>
</footer>