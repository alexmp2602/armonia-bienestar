---
import { Menu, X } from "lucide-astro";
import Button from "../ui/Button.astro";
import logo from "../../assets/images/logo-horizontal-sin-fondo.webp";
---

<header
  class="fixed left-0 top-0 z-50 w-full border-b border-black/5 bg-[#f5f2ed]/85 backdrop-blur-xl"
>
  <div class="container flex h-20 items-center justify-between">
    <a
      href="/"
      class="flex items-center gap-3"
      aria-label="Ir al inicio de Armonía & Bienestar"
    >
      <img
        src={logo.src}
        alt="Armonía & Bienestar"
        class="h-12 w-auto select-none"
        draggable="false"
      />
    </a>

    <nav
      class="hidden items-center gap-8 text-sm font-medium text-black/60 md:flex"
      aria-label="Navegación principal"
    >
      <a href="#servicios" class="transition duration-300 hover:text-black">
        Servicios
      </a>

      <a href="#experiencia" class="transition duration-300 hover:text-black">
        Experiencia
      </a>

      <a href="#espacio" class="transition duration-300 hover:text-black">
        Espacio
      </a>

      <a href="#contacto" class="transition duration-300 hover:text-black">
        Contacto
      </a>
    </nav>

    <div class="hidden md:block">
      <Button href="#contacto">Reservar por WhatsApp</Button>
    </div>

    <details class="group relative md:hidden">
      <summary
        class="flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-full border border-black/10 bg-white/40 text-black transition hover:bg-white/70"
        aria-label="Abrir menú"
      >
        <Menu
          class="group-open:hidden"
          size={20}
          strokeWidth={1.75}
          aria-hidden="true"
        />

        <X
          class="hidden group-open:block"
          size={20}
          strokeWidth={1.75}
          aria-hidden="true"
        />
      </summary>

      <div
        class="absolute right-0 top-14 w-[min(82vw,320px)] overflow-hidden rounded-3xl border border-black/10 bg-[#f5f2ed]/95 p-3 shadow-2xl shadow-black/10 backdrop-blur-xl"
      >
        <nav class="flex flex-col text-sm font-medium text-black/70">
          <a
            href="#servicios"
            class="rounded-2xl px-4 py-3 transition hover:bg-black/[0.04] hover:text-black"
          >
            Servicios
          </a>

          <a
            href="#experiencia"
            class="rounded-2xl px-4 py-3 transition hover:bg-black/[0.04] hover:text-black"
          >
            Experiencia
          </a>

          <a
            href="#espacio"
            class="rounded-2xl px-4 py-3 transition hover:bg-black/[0.04] hover:text-black"
          >
            Espacio
          </a>

          <a
            href="#contacto"
            class="rounded-2xl px-4 py-3 transition hover:bg-black/[0.04] hover:text-black"
          >
            Contacto
          </a>

          <div class="mt-2 border-t border-black/10 pt-3">
            <Button href="#contacto">Reservar por WhatsApp</Button>
          </div>
        </nav>
      </div>
    </details>
  </div>
</header>