---
import "../styles/global.css";
import RevealScript from "../components/motion/RevealScript.astro";

const {
  title = "Armonía & Bienestar | Terapia de Masajes",
  description = "Un espacio de bienestar, relajación y recuperación física diseñado para desconectar del ritmo diario.",
  image = "/og-image.jpg",
  url = "https://armonia-bienestar.vercel.app/",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <!-- Basic -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>

    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#F5F2ED" />

    <!-- Canonical -->
    <link rel="canonical" href={url} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.ico" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_AR" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content="Armonía & Bienestar" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Performance -->
    <meta name="format-detection" content="telephone=no" />
  </head>

  <body>
    <slot />
    <RevealScript />
  </body>
</html>
