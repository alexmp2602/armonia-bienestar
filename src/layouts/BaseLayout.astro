---
import "../styles/global.css";
import RevealScript from "../components/motion/RevealScript.astro";

const {
  title = "Armonía & Bienestar | Masajes y Bienestar Masculino en Mendoza",
  description = "Masajes, recuperación corporal y cuidado personal masculino en Mendoza. Un espacio moderno, reservado y profesional pensado para el bienestar y la relajación.",
  image = "/og-image.jpg",
  url = "https://armoniaybienestar.com/",
} = Astro.props;

const canonicalUrl = url.endsWith("/") ? url : `${url}/`;
const imageUrl = new URL(image, canonicalUrl).toString();
---

<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>

    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#F5F2ED" />
    <meta name="format-detection" content="telephone=no" />

    <link rel="canonical" href={canonicalUrl} />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content="Armonía & Bienestar" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta
      property="og:image:alt"
      content="Armonía & Bienestar, bienestar masculino premium"
    />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "HealthAndBeautyBusiness",
        name: "Armonía & Bienestar",
        description,
        url: canonicalUrl,
        image: imageUrl,
        telephone: "+5492616215017",
        address: {
          "@type": "PostalAddress",
          streetAddress: "Avenida Pedro Molina 789",
          addressLocality: "Ciudad",
          addressRegion: "Mendoza",
          addressCountry: "AR",
        },
        openingHoursSpecification: [
          {
            "@type": "OpeningHoursSpecification",
            dayOfWeek: [
              "Monday",
              "Tuesday",
              "Wednesday",
              "Thursday",
              "Friday",
              "Saturday",
            ],
            opens: "09:00",
            closes: "21:00",
          },
          {
            "@type": "OpeningHoursSpecification",
            dayOfWeek: "Sunday",
            opens: "10:00",
            closes: "18:00",
          },
        ],
        areaServed: "Mendoza, Argentina",
        sameAs: [],
      })}
    />
  </head>

  <body>
    <slot />
    <RevealScript />
  </body>
</html>
